# Auth.js
AUTH_SECRET=            # generate with: npx auth secret
AUTH_GOOGLE_ID=         # from Google Cloud OAuth client
AUTH_GOOGLE_SECRET=

# MongoDB Atlas
MONGODB_URI=            # mongodb+srv://...
MONGODB_DB=altrotemarr

# Access control (comma-separated, lowercase)
ALLOWED_EMAILS=nestor.daza@gmail.com,lilo.ayala@gmail.com

# Web Push (daily reminder). Generate keys with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=   # public key, sent to the browser
VAPID_PUBLIC_KEY=               # same public key, server-side
VAPID_PRIVATE_KEY=              # private key, server-side only
VAPID_SUBJECT=mailto:you@example.com
NOTIFY_HOUR=7                   # local Toronto hour for the daily send (0-23)

# Vercel Cron auth (any long random string; Vercel injects it as a Bearer token)
CRON_SECRET=
